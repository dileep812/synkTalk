# Database Configuration
DATABASE_URL=mongodb://localhost:27017/synktalk

# Redis Cache & Message Queue Url
REDIS_URL=redis://localhost:6379

# Server Configuration
PORT=5000
NODE_ENV=development
SESSION_SECRET=synktalk-development-secret-key-change-in-production

# CORS Client Allowed Origin
CLIENT_URL=http://localhost:5173

# Gmail OAuth2 Verification SMTP configuration
EMAIL_USER=your_email@gmail.com
GMAIL_CLIENT_ID=your_gmail_client_id
GMAIL_CLIENT_SECRET=your_gmail_client_secret
GMAIL_REFRESH_TOKEN=your_gmail_refresh_token
